<div class="crp-attack-dialog">
  <label for="crp-attack-modifier">Modyfikator ataku: <output for="crp-attack-modifier" class="crp-attack-modifier-value">+0</output></label>
  <div class="crp-attack-modifier-row">
    <span>-4</span>
    <input id="crp-attack-modifier"
           type="range"
           name="attackModifier"
           min="-4"
           max="4"
           step="1"
           value="0">
    <span>+4</span>
    
  </div>
<label for="crp-attack-modifier">Dostępne Punkty Manewru: {{maneuver.value}} / {{maneuver.max}}</label>

  <label for="crp-attack-maneuver">Manewr</label>
  <select id="crp-attack-maneuver" name="maneuver">
    {{#each maneuvers as |maneuver|}}
      <option value="{{maneuver.key}}"
              data-cost="{{maneuver.cost}}"
              data-description="{{maneuver.description}}"
              {{#if (eq maneuver.key "none")}}selected{{/if}}>
        {{maneuver.displayName}} (koszt: {{maneuver.cost}})
      </option>
    {{/each}}
  </select>

  <div class="crp-attack-maneuver-description"></div>

</div>
