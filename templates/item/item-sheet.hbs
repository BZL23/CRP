<section class="crp-item">

  <div class="crp-item-header">

    <div class="crp-item-left">
      <h1>
  <input type="text" data-path="name" value="{{item.name}}">
</h1>
    </div>

    <div class="crp-item-img">
      <img src="{{item.img}}" data-edit="img">
    </div>

  </div>

  <div class="crp-item-description">
    <textarea data-path="system.description">{{system.description}}</textarea>
  </div>

  <hr>

  <div class="crp-form">

    <label>Obrażenia</label>
    <input type="number"
           data-path="system.damage"
           value="{{system.damage}}">

<label>Umiejętność</label>

<select data-path="system.skill">

  {{#each config.combatSkills as |key|}}
    <option value="{{key}}"
      {{#if (eq key ../system.skill)}}selected{{/if}}>
      {{lookup ../config.skills key}}
    </option>
  {{/each}}

</select>

    <label>Rodzaj broni</label>
    <select data-path="system.hands">
  <option value="1" {{#if (eq system.hands 1)}}selected{{/if}}>Jednoręczna</option>
  <option value="2" {{#if (eq system.hands 2)}}selected{{/if}}>Dwuręczna</option>
</select>

    <label>Zasięg</label>
    <select data-path="system.range">
      <option value="melee" {{#if (eq system.range "melee")}}selected{{/if}}>Wręcz</option>
      <option value="ranged" {{#if (eq system.range "ranged")}}selected{{/if}}>Dystans</option>
    </select>

    <label>Waga</label>
    <select data-path="system.weight">
      {{#each config.itemWeights as |label key|}}
        <option value="{{key}}" {{#if (eq key ../itemWeight)}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>


<hr>

<div class="crp-price-section">

  <div class="crp-price-header">
    Cena:
    <span class="crp-price-summary">
      {{formattedPrice}}
    </span>
  </div>

  <div class="crp-price-grid">

    <div class="crp-price-row">
      <label>Floreny</label>
      <input
        type="number"
        min="0"
        value="{{system.price.floren}}"
        data-path="system.price.floren">
    </div>

    <div class="crp-price-row">
      <label>Grzywny</label>
      <input
        type="number"
        min="0"
        value="{{system.price.grzywna}}"
        data-path="system.price.grzywna">
    </div>

    <div class="crp-price-row">
      <label>Skojce</label>
      <input
        type="number"
        min="0"
        value="{{system.price.skojec}}"
        data-path="system.price.skojec">
    </div>

    <div class="crp-price-row">
      <label>Grosze</label>
      <input
        type="number"
        min="0"
        value="{{system.price.grosz}}"
        data-path="system.price.grosz">
    </div>

    <div class="crp-price-row">
      <label>Kwartniki</label>
      <input
        type="number"
        min="0"
        value="{{system.price.kwartnik}}"
        data-path="system.price.kwartnik">
    </div>

    <div class="crp-price-row">
      <label>Denary</label>
      <input
        type="number"
        min="0"
        value="{{system.price.denar}}"
        data-path="system.price.denar">
    </div>

    <div class="crp-price-row">
      <label>Obole</label>
      <input
        type="number"
        min="0"
        value="{{system.price.obol}}"
        data-path="system.price.obol">
    </div>

  </div>

</div>

  </div>

</section>
