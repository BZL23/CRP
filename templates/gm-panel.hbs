<div class="crp-gm-panel">

  <h2 class="crp-panel-title">Panel MG</h2>

  <div class="crp-panel-section">
    <h3>🎲 Dola</h3>

    <div class="crp-actor-list">
      {{#each actors}}
        <label class="crp-actor-row">
          <input type="checkbox" value="{{this.id}}">
          <span>{{this.name}}</span>
          <span class="crp-fate">Dola: {{this.fate}} / {{this.fateMax}}</span>
          <span class="crp-xp">PD: {{this.experience}}</span>
        </label>
      {{/each}}
    </div>

    <div class="crp-panel-grid">
      <button data-action="toggle-all">Zaznacz wszystkich</button>

      <button data-action="reset-fate">
        Reset Doli
      </button>

      <button data-action="give-fate-selected">
        +1 Doli
      </button>

      <button data-action="give-xp-selected">
        Rozdaj PD
      </button>
    </div>
  </div>

  <div class="crp-panel-section">
    <h3>❤️ Zdrowie</h3>

    <div class="crp-panel-grid">
      <button data-action="heal-all">
        Wylecz wszystkich
      </button>
    </div>
  </div>

  <div class="crp-panel-section">
    <h3>⚙️ Narzędzia</h3>

    <div class="crp-panel-grid">
      <button data-action="refresh">
        Odśwież aktorów
      </button>

      <button data-action="toggle-sheet-lock">
        {{#if characterSheetsLocked}}Odblokuj karty{{else}}Zablokuj karty{{/if}}
      </button>

      <button data-action="clear-advancement-logs">
        Wyczyść logi rozwoju
      </button>

      <button data-action="add-advancement-log">
        Dodaj wpis do logu
      </button>
    </div>
  </div>

</div>
